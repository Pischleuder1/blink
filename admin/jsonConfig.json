{
  "i18n": true,
  "type": "tabs",
  "tabsStyle": {
    "width": "calc(100% - 100px)"
  },
  "items": {
    "tab_connection": {
      "type": "panel",
      "label": "Connection",
      "items": {
        "email": {
          "type": "text",
          "label": "Blink Benutzername / E-Mail",
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "password": {
          "type": "password",
          "label": "Passwort",
          "newLine": true,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "pin": {
          "type": "password",
          "label": "PIN / 2FA-Code (optional)",
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "settings_header": {
          "type": "header",
          "text": "Settings",
          "size": 4,
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "pollIntervalSec": {
          "type": "number",
          "label": "Status-Polling Intervall (Sek.)",
          "min": 15,
          "max": 3600,
          "default": 60,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "snapshotDir": {
          "type": "text",
          "label": "Snapshot-Verzeichnis",
          "default": "/opt/iobroker/iobroker-data/blinkpy",
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "debugLogEnabled": {
          "type": "checkbox",
          "label": "Blink Debug-Log aktivieren",
          "help": "Schreibt /tmp/blink_debug.log",
          "default": false,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "liveSnapshotEnabled": {
          "type": "checkbox",
          "label": "Livebild per Snapshot aktivieren",
          "default": true,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "liveSnapshotIntervalSec": {
          "type": "number",
          "label": "Livebild Intervall (Sek.)",
          "min": 5,
          "max": 3600,
          "default": 10,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "storeBase64": {
          "type": "checkbox",
          "label": "Bild zusätzlich als Base64-Data-URL im State speichern",
          "default": true,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "cleanupOldSnapshots": {
          "type": "checkbox",
          "label": "Alte Snapshot-Dateien automatisch löschen",
          "default": true,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        },
        "maxSnapshotAgeHours": {
          "type": "number",
          "label": "Max. Alter Snapshot-Dateien (Stunden)",
          "min": 1,
          "max": 168,
          "default": 24,
          "sm": 12,
          "xs": 12,
          "lg": 4,
          "xl": 4,
          "md": 6
        }
      }
    },
    "tab_notifications": {
      "type": "panel",
      "label": "Notifications",
      "items": {
        "notify_batt_header": {
          "type": "header",
          "text": "Batteriewarnung",
          "size": 4,
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "batteryWarningEnabled": {
          "type": "checkbox",
          "label": "Batteriewarnung aktivieren",
          "default": false,
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "batteryWarningThresholdVolt": {
          "type": "number",
          "label": "Grenzwert Batteriespannung (V)",
          "default": 1.1,
          "min": 0,
          "max": 5,
          "step": 0.01,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "batteryWarningCooldownHours": {
          "type": "number",
          "label": "Warn-Cooldown pro Kamera (Stunden)",
          "default": 24,
          "min": 1,
          "max": 720,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "notify_batt_info": {
          "type": "header",
          "text": "Kanäle für die Batteriewarnung:",
          "size": 5,
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "battery_telegram_enabled": {
          "type": "checkbox",
          "label": "Telegram aktivieren",
          "default": false,
          "newLine": true,
          "hidden": "!data.batteryWarningEnabled",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "battery_telegram_instance": {
          "type": "instance",
          "adapter": "telegram",
          "label": "Telegram Instanz",
          "default": "telegram.0",
          "hidden": "!data.batteryWarningEnabled || !data.battery_telegram_enabled",
          "newLine": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "battery_telegram_users": {
          "type": "text",
          "label": "Empfänger (User, kommagetrennt – leer = alle)",
          "default": "",
          "hidden": "!data.batteryWarningEnabled || !data.battery_telegram_enabled",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "battery_pushover_enabled": {
          "type": "checkbox",
          "label": "Pushover aktivieren",
          "default": false,
          "newLine": true,
          "hidden": "!data.batteryWarningEnabled",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "battery_pushover_instance": {
          "type": "instance",
          "adapter": "pushover",
          "label": "Pushover Instanz",
          "default": "pushover.0",
          "hidden": "!data.batteryWarningEnabled || !data.battery_pushover_enabled",
          "newLine": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "battery_email_enabled": {
          "type": "checkbox",
          "label": "E-Mail aktivieren",
          "default": false,
          "newLine": true,
          "hidden": "!data.batteryWarningEnabled",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "battery_email_instance": {
          "type": "instance",
          "adapter": "email",
          "label": "E-Mail Instanz",
          "default": "email.0",
          "hidden": "!data.batteryWarningEnabled || !data.battery_email_enabled",
          "newLine": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "battery_email_to": {
          "type": "text",
          "label": "Empfänger E-Mail (leer = Standard aus email-Adapter)",
          "default": "",
          "hidden": "!data.batteryWarningEnabled || !data.battery_email_enabled",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "notify_motion_header": {
          "type": "header",
          "text": "Bewegungsbenachrichtigung",
          "size": 4,
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "motionNotifyEnabled": {
          "type": "checkbox",
          "label": "Bewegungsbenachrichtigung aktivieren",
          "default": false,
          "newLine": true,
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "motionNotifyCooldownMinutes": {
          "type": "number",
          "label": "Cooldown pro Kamera (Minuten)",
          "default": 5,
          "min": 1,
          "max": 1440,
          "hidden": "!data.motionNotifyEnabled",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4
        },
        "notify_motion_info": {
          "type": "header",
          "text": "Kanäle für die Bewegungsbenachrichtigung:",
          "size": 5,
          "newLine": true,
          "hidden": "!data.motionNotifyEnabled",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "motion_telegram_enabled": {
          "type": "checkbox",
          "label": "Telegram aktivieren",
          "default": false,
          "newLine": true,
          "hidden": "!data.motionNotifyEnabled",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "motion_telegram_instance": {
          "type": "instance",
          "adapter": "telegram",
          "label": "Telegram Instanz",
          "default": "telegram.0",
          "hidden": "!data.motionNotifyEnabled || !data.motion_telegram_enabled",
          "newLine": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "motion_telegram_users": {
          "type": "text",
          "label": "Empfänger (User, kommagetrennt – leer = alle)",
          "default": "",
          "hidden": "!data.motionNotifyEnabled || !data.motion_telegram_enabled",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        },
        "motion_pushover_enabled": {
          "type": "checkbox",
          "label": "Pushover aktivieren",
          "default": false,
          "newLine": true,
          "hidden": "!data.motionNotifyEnabled",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "motion_pushover_instance": {
          "type": "instance",
          "adapter": "pushover",
          "label": "Pushover Instanz",
          "default": "pushover.0",
          "hidden": "!data.motionNotifyEnabled || !data.motion_pushover_enabled",
          "newLine": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "motion_email_enabled": {
          "type": "checkbox",
          "label": "E-Mail aktivieren",
          "default": false,
          "newLine": true,
          "hidden": "!data.motionNotifyEnabled",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
        "motion_email_instance": {
          "type": "instance",
          "adapter": "email",
          "label": "E-Mail Instanz",
          "default": "email.0",
          "hidden": "!data.motionNotifyEnabled || !data.motion_email_enabled",
          "newLine": true,
          "xs": 12,
          "sm": 6,
          "md": 4,
          "lg": 4,
          "xl": 4
        },
        "motion_email_to": {
          "type": "text",
          "label": "Empfänger E-Mail (leer = Standard aus email-Adapter)",
          "default": "",
          "hidden": "!data.motionNotifyEnabled || !data.motion_email_enabled",
          "xs": 12,
          "sm": 6,
          "md": 6,
          "lg": 6,
          "xl": 6
        }
      }
    }
  }
}